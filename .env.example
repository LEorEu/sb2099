# sb2099 运行时配置
# 复制为 .env 并填入真实值；.env 不入仓

# 管理员后台 Token（无默认值，未设置启动报错退出）
# 生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
SB2099_ADMIN_TOKEN=

# IP 哈希盐（用于 sha256(ip + salt)[:16]，落库前匿名化）
# 生成同上
SB2099_IP_SALT=

# 目标房间号（短号 2099 对应真实房间 12740109）
# 抓取层直连 danmuproxy.douyu.com:8601（硬编码），不需要再配 ws 上游
DOUYU_ROOM_ID=12740109

# SQLite 数据库路径
SB2099_DB_PATH=./sb2099.db
